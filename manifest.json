{
  "manifest_version": 2,
  "name": "YouTube Focus Guard",
  "version": "1.0.0",
  "description": "Prevent YouTube binge watching, algorithm rabbit holes, and protect sleep schedules while allowing intentional research",
  
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "*://www.youtube.com/*",
    "*://youtube.com/*"
  ],

  "background": {
    "scripts": [
      "utils/storage.js",
      "utils/time.js",
      "background/scheduler.js", 
      "background/usageTracker.js"
    ],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*", "*://youtube.com/*"],
      "js": [
        "content/recommendationBlocker.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": ["*://www.youtube.com/*", "*://youtube.com/*"],
      "js": [
        "utils/storage.js",
        "utils/time.js",
        "content/browsingMode.js",
        "content/timerOverlay.js",
        "content/topicGuard.js",
        "content/youtubeObserver.js"
      ],
      "css": ["styles/ui.css"],
      "run_at": "document_idle"
    }
  ],

  "browser_action": {
    "default_popup": "ui/popup.html",
    "default_title": "YouTube Focus Guard",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "web_accessible_resources": [
    "ui/blocked.html",
    "ui/modal.html",
    "styles/ui.css"
  ],

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png", 
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}